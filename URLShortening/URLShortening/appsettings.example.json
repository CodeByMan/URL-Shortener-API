{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=UrlShorteningDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "JWT": {
    "Key": "replace-with-a-random-key-at-least-32-characters-long",
    "Issuer": "URLShorteningApi",
    "Audience": "URLShorteningClients",
    "AccessTokenMinutes": 60
  },
  "EmailSettings": {
    "Email": "your-email@example.com",
    "Password": "replace-with-an-app-password",
    "Smtp": "smtp.example.com",
    "Port": "587",
    "DisplayName": "URL Shortening"
  },
  "CodeKey": "replace-with-a-random-email-confirmation-hashing-key",
  "EmailConfirmation": {
    "CodeLifetimeMinutes": 15
  },
  "GeoLocation": {
    "BaseUrl": "https://ipwho.is/",
    "TimeoutSeconds": 3
  },
  "RateLimiting": {
    "AuthenticationPermitLimit": 10,
    "AnonymousCreationPermitLimit": 10,
    "AuthenticatedCreationPermitLimit": 60,
    "PublicRedirectPermitLimit": 240,
    "AnalyticsPermitLimit": 30
  },
  "ForwardedHeaders": {
    "KnownProxies": [
      "127.0.0.1"
    ]
  }
}
