{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JWT": {
    "AccessTokenMinutes": 60
  },
  "EmailConfirmation": {
    "CodeLifetimeMinutes": 15
  },
  "GeoLocation": {
    "BaseUrl": "https://ipwho.is/",
    "TimeoutSeconds": 3
  },
  "RateLimiting": {
    "AuthenticationPermitLimit": 10,
    "AnonymousCreationPermitLimit": 10,
    "AuthenticatedCreationPermitLimit": 60,
    "PublicRedirectPermitLimit": 240,
    "AnalyticsPermitLimit": 30
  },
  "ForwardedHeaders": {
    "KnownProxies": []
  }
}
