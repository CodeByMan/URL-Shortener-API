using System.IdentityModel.Tokens.Jwt;
using System.Security.Claims;
using Microsoft.AspNetCore.Http;
using Microsoft.AspNetCore.Identity;
using Microsoft.AspNetCore.Mvc;
using Microsoft.Extensions.Configuration;
using URLShortening.Controllers;
using URLShortening.Data;
using URLShortening.DTOs;
using URLShortening.Helpers;
using URLShortening.Models;
using URLShortening.Services;

namespace URLShortening.Tests;

public class AuthControllerTests
{
    [Fact]
    public async Task ExistingUnconfirmedAccount_ReceivesNewCode()
    {
        var user = CreateUser(emailConfirmed: false);
        var helper = new FakeUserHelper(user);
        var mail = new FakeMailService(success: true);
        var controller = CreateController(helper, mail);

        var result = await controller.Register(new AuthDto
        {
            Email = user.Email!,
            Password = "Password123!"
        });

        Assert.IsType<AcceptedResult>(result);
        Assert.Equal(1, mail.SendCount);
        Assert.NotNull(user.EmailConfirmationCodeHash);
        Assert.True(user.EmailConfirmationCodeExpiresAt > DateTime.UtcNow);
    }

    [Fact]
    public async Task FailedEmailDelivery_ClearsUndeliveredCodeAndAllowsResend()
    {
        var helper = new FakeUserHelper();
        var mail = new FakeMailService(success: false);
        var controller = CreateController(helper, mail);

        var result = await controller.Register(new AuthDto
        {
            Email = "new@example.com",
            Password = "Password123!"
        });

        var unavailable = Assert.IsType<ObjectResult>(result);
        Assert.Equal(StatusCodes.Status503ServiceUnavailable,
            unavailable.StatusCode);
        Assert.NotNull(helper.User);
        Assert.Null(helper.User!.EmailConfirmationCodeHash);
        Assert.Null(helper.User.EmailConfirmationCodeExpiresAt);
    }

    [Fact]
    public async Task ExpiredConfirmationCode_IsRejected()
    {
        var codeHelper = new CodeGeneratorHelper();
        var user = CreateUser(emailConfirmed: false);
        var code = "123456";
        user.EmailConfirmationCodeHash = codeHelper.HashConfirmationCode(
            code, user.Id, "confirmation-secret");
        user.EmailConfirmationCodeExpiresAt = DateTime.UtcNow.AddMinutes(-1);
        var helper = new FakeUserHelper(user);
        var controller = CreateController(helper,
            new FakeMailService(success: true),
            codeHelper);

        var result = await controller.ConfirmEmail(new EmailConfirmationDto
        {
            Email = user.Email!,
            ConfirmationCode = code
        });

        Assert.IsType<BadRequestObjectResult>(result);
        Assert.False(user.EmailConfirmed);
        Assert.Equal(0, helper.ConfirmCount);
    }

    [Fact]
    public async Task Login_UsesConfiguredShortLifetimeAndSecurityStamp()
    {
        var user = CreateUser(emailConfirmed: true);
        var helper = new FakeUserHelper(user);
        var controller = CreateController(helper,
            new FakeMailService(success: true));

        var result = await controller.Login(new AuthDto
        {
            Email = user.Email!,
            Password = "Password123!"
        });

        var ok = Assert.IsType<OkObjectResult>(result);
        var tokenProperty = ok.Value!.GetType().GetProperty("AccessToken");
        var tokenValue = Assert.IsType<string>(tokenProperty!.GetValue(ok.Value));
        var token = new JwtSecurityTokenHandler().ReadJwtToken(tokenValue);

        Assert.InRange((token.ValidTo - token.ValidFrom).TotalMinutes,
            59,
            61);
        Assert.Contains(token.Claims, claim =>
            claim.Type == "security_stamp" &&
            claim.Value == user.SecurityStamp);
    }

    [Fact]
    public async Task Logout_UpdatesSecurityStampToRevokeExistingTokens()
    {
        var user = CreateUser(emailConfirmed: true);
        var helper = new FakeUserHelper(user);
        var controller = CreateController(helper,
            new FakeMailService(success: true));
        controller.ControllerContext = new ControllerContext
        {
            HttpContext = new DefaultHttpContext
            {
                User = new ClaimsPrincipal(new ClaimsIdentity(
                [
                    new Claim(ClaimTypes.NameIdentifier, user.Id)
                ], "Test"))
            }
        };

        var result = await controller.Logout();

        Assert.IsType<NoContentResult>(result);
        Assert.Equal(1, helper.SecurityStampUpdateCount);
    }

    private static AuthController CreateController(
        FakeUserHelper userHelper,
        FakeMailService mailService,
        ICodeGeneratorHelper? codeGeneratorHelper = null)
    {
        var configuration = new ConfigurationBuilder()
            .AddInMemoryCollection(new Dictionary<string, string?>
            {
                ["JWT:Key"] = "a-secure-test-key-with-at-least-32-characters",
                ["JWT:Issuer"] = "URLShorteningApi",
                ["JWT:Audience"] = "URLShorteningClients",
                ["JWT:AccessTokenMinutes"] = "60",
                ["CodeKey"] = "confirmation-secret",
                ["EmailConfirmation:CodeLifetimeMinutes"] = "15"
            })
            .Build();

        return new AuthController(userHelper,
            mailService,
            configuration,
            codeGeneratorHelper ?? new CodeGeneratorHelper());
    }

    private static User CreateUser(bool emailConfirmed)
    {
        return new User
        {
            Id = Guid.NewGuid().ToString(),
            Email = "user@example.com",
            UserName = "user@example.com",
            EmailConfirmed = emailConfirmed,
            SecurityStamp = Guid.NewGuid().ToString()
        };
    }

    private sealed class FakeMailService(bool success) : IMailService
    {
        public int SendCount { get; private set; }

        public Task<ResponseResultModel> SendEmailAsync(string email,
            string subject,
            string body)
        {
            SendCount++;
            return Task.FromResult(new ResponseResultModel
            {
                IsSuccess = success,
                ErrorMessage = success ? null : "SMTP unavailable."
            });
        }
    }

    private sealed class FakeUserHelper(User? initialUser = null) : IUserHelper
    {
        public User? User { get; private set; } = initialUser;
        public int ConfirmCount { get; private set; }
        public int SecurityStampUpdateCount { get; private set; }

        public Task<bool> CreateUserAsync(User newUser, string password)
        {
            newUser.SecurityStamp ??= Guid.NewGuid().ToString();
            User = newUser;
            return Task.FromResult(true);
        }

        public Task<string> GenerateEmailConfirmationTokenAsync(User user) =>
            Task.FromResult("identity-confirmation-token");

        public Task<IdentityResult> ConfirmEmailAsync(User user, string token)
        {
            ConfirmCount++;
            user.EmailConfirmed = true;
            return Task.FromResult(IdentityResult.Success);
        }

        public Task<string> GeneratePasswordResetTokenAsync(User user) =>
            throw new NotSupportedException();

        public Task<IdentityResult> ResetPasswordAsync(User user,
            string token,
            string password) => throw new NotSupportedException();

        public Task<SignInResult> LoginAsync(string modelEmail,
            string modelPassword,
            bool modelRememberMe) => throw new NotSupportedException();

        public Task LogoutAsync() => throw new NotSupportedException();

        public Task<IdentityResult> UpdateUserAsync(User user) =>
            Task.FromResult(IdentityResult.Success);

        public Task<IdentityResult> UpdateSecurityStampAsync(User user)
        {
            SecurityStampUpdateCount++;
            user.SecurityStamp = Guid.NewGuid().ToString();
            return Task.FromResult(IdentityResult.Success);
        }

        public Task<IdentityResult> ChangePasswordAsync(User user,
            string oldPassword,
            string newPassword) => throw new NotSupportedException();

        public Task<bool> CheckPasswordAsync(User user, string password) =>
            Task.FromResult(true);

        public Task<IdentityResult> DeleteUserAsync(User user) =>
            throw new NotSupportedException();

        public Task<User?> FindUserByEmailAsync(string email) =>
            Task.FromResult(User?.Email == email ? User : null);

        public Task<User?> FindUserByIdAsync(string id) =>
            Task.FromResult(User?.Id == id ? User : null);

        public Task<User?> FindUserByEmailIncludeUrlsAsync(string email) =>
            Task.FromResult(User?.Email == email ? User : null);
    }
}
